{
  "name": "Purchase-Requisition-App",
  "version": "1.0.0",
  "dependencies": {
    "@cap-js/attachments": "^3.13.1",
    "@cap-js/hana": "^2",
    "@sap/cds": "^9",
    "@sap/xssec": "^4"
  },
  "devDependencies": {
    "@cap-js/cds-typer": ">=0.1",
    "@cap-js/cds-types": "^0.18.0",
    "@cap-js/sqlite": "^2.4",
    "@sap/cds-dk": "^9",
    "@types/node": "^24.0.0",
    "cds-plugin-ui5": "^0.17.0",
    "mbt": "^1.2.49",
    "rimraf": "^5.0.5",
    "tsx": "^4",
    "typescript": "^6.0.0"
  },
  "scripts": {
    "start": "cds-serve",
    "watch-purchase-requisitions": "cds watch --open com.jvg.purchasereq.requisitions.purchaserequisitions/index.html?sap-ui-xx-viewCache=false --livereload false",
    "undeploy": "cf undeploy Purchase-Requisition-App --delete-services --delete-service-keys --delete-service-brokers",
    "build": "rimraf resources mta_archives && mbt build --mtar archive",
    "deploy": "cf deploy mta_archives/archive.mtar --retries 1"
  },
  "private": true,
  "cds": {
    "requires": {
      "[production]": {
        "auth": "xsuaa"
      },
      "[development]": {
        "auth": {
          "kind": "mocked",
          "users": {
            "emp": {
              "password": "pwd",
              "roles": [
                "Employee"
              ]
            },
            "emp2": {
              "password": "pwd",
              "roles": [
                "Employee"
              ]
            },
            "mgr": {
              "password": "pwd",
              "roles": [
                "Manager"
              ]
            },
            "proc": {
              "password": "pwd",
              "roles": [
                "Procurement"
              ]
            },
            "admin": {
              "password": "pwd",
              "roles": [
                "Admin"
              ]
            }
          }
        }
      },
      "attachments": {
        "maxFileSizeMB": 10,
        "allowedMimeTypes": ["application/pdf", "image/png", "image/jpeg"]
      }

    }
  },
  "imports": {
    "#cds-models/*": "./@cds-models/*/index.js"
  },
  "workspaces": [
    "app/*"
  ],
  "sapux": [
    "app/purchase-requisitions"
  ]
}
